&"1_1": {
"dialogue": "~~Towers on sand...
Blue in the sky!",
"offset": Vector2(-780, 120),
"options": {
0: {
"condition": {},
"link": &"1_9",
"text": ""
}
},
"size": Vector2(300.0005, 240.00018),
"speaker": 1
},
&"1_2": {
"dialogue": "Wow, did you just make that up?",
"offset": Vector2(-20, 140),
"options": {
0: {
"condition": {},
"link": &"1_3",
"text": ""
}
},
"size": Vector2(300.00012, 240.00012),
"speaker": 0
},
&"1_3": {
"dialogue": "It's part of a song I heard as a kid.",
"offset": Vector2(320, 140),
"options": {
0: {
"condition": {},
"link": &"1_4",
"text": ""
}
},
"size": Vector2(300, 240.00012),
"speaker": 1
},
&"1_4": {
"dialogue": "The funny part is... the first time I heard it, I'd never even seen a blue sky. ",
"offset": Vector2(660, 140),
"options": {
0: {
"condition": {},
"link": &"1_8",
"text": ""
}
},
"size": Vector2(300, 240),
"speaker": 1
},
&"1_5": {
"dialogue": "Yet here we are.",
"offset": Vector2(1440, 160),
"options": {
0: {
"condition": {},
"link": &"1_6",
"text": ""
}
},
"size": Vector2(300, 240.00023),
"speaker": 1
},
&"1_6": {
"dialogue": "If we look hard enough, I bet we could find a sky for every color.",
"offset": Vector2(1760, 160),
"options": {
0: {
"condition": {},
"link": &"1_7",
"text": ""
}
},
"size": Vector2(300, 240.00023),
"speaker": 0
},
&"1_7": {
"dialogue": "Sure. Why not? I think I could believe anything at this point.",
"offset": Vector2(2080, 160),
"options": {
0: {
"condition": {},
"link": "END",
"text": ""
}
},
"size": Vector2(300, 240.00023),
"speaker": 1
},
&"1_8": {
"dialogue": "I actually didn't think they were real. Just part of an absurd rhyme for kids. ",
"offset": Vector2(1060, 160),
"options": {
0: {
"condition": {},
"link": &"1_5",
"text": ""
}
},
"size": Vector2(300, 240.0001),
"speaker": 1
},
&"1_9": {
"dialogue": "Don't they look grand as the ages go by?~~",
"offset": Vector2(-420, 140),
