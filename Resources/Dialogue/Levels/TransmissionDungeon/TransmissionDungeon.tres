},
&"1_27": {
"dialogue": "Let's let bygones be bygones. You dropped me in a pit and I dropped you in one. Fair's fair.     -Tess",
"offset": Vector2(680, 4540),
"options": {
0: {
"condition": {},
"link": "END",
"text": ""
}
},
"size": Vector2(339.99988, 360),
