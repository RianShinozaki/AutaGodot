; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

warnings/check_invalid_track_paths=false
warnings/check_angle_interpolation_type_conflicting=false
compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="AutaGodot"
run/main_scene="uid://bb7vw7fvmejei"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://Scripts/icon.svg"

[audio]

buses/default_bus_layout="uid://c26fit5d5jho4"

[autoload]

Music="*uid://m65mqk4g3464"
DialogueManager="*uid://c3rodes2l3gxb"

[dialogic]

directories/dch_directory={
"Auta": "res://Art Assets/UI/Dialogue/Auta.dch",
"Tess": "res://Resources/Dialogic/Tess.dch"
}
directories/dtl_directory={
"tess_test": "res://Resources/Dialogic/tess_test.dtl"
}
layout/style_directory={
"": "res://Art Assets/UI/Dialogue/dialogic_theme.tres",
"dialogic_theme": "res://Art Assets/UI/Dialogue/dialogic_theme.tres"
}
layout/style_list=["res://Art Assets/UI/Dialogue/dialogic_theme.tres"]
layout/default_style="res://Art Assets/UI/Dialogue/dialogic_theme.tres"
glossary/default_case_sensitive=true
variables={
"WasADickToScav": false,
"WasEditorNecessary": false
}
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=false
animations/leave_default_length=0.5
animations/leave_default_wait=false
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
animations/join_default="Instant In"
animations/leave_default="Instant Out"
animations/cross_fade_default="Fade Cross"

[dialogue_manager]

runtime/advanced/uses_dotnet=true
runtime/balloon_path="res://Objects/UI/Dialogue/Balloon.tscn"
editor/new_file_template="~ start

=> END"

[display]

window/size/viewport_width=1536
window/size/viewport_height=864
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"

[dotnet]

project/assembly_name="Auta"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/kenyoni/plugin_reloader/plugin.cfg")

[file_customization]

folder_colors={
"res://Art Assets/": "red",
"res://Audio/": "green",
"res://Maps/": "teal",
"res://Objects/": "pink",
"res://Resources/": "yellow",
"res://Resources/Tilesets/": "orange",
"res://Scripts/": "blue",
"res://Shaders/": "purple",
"res://Unused/": "gray",
"res://addons/": "gray"
}

